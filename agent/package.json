{
  "name": "trustwipe-agent",
  "version": "1.0.0",
  "description": "TrustWipe Enterprise Secure Data Wiping Agent",
  "type": "module",
  "main": "./core/socketClient.js",
  "bin": {
    "trustwipe-agent": "./core/socketClient.js"
  },
  "scripts": {
    "start": "node ./core/socketClient.js",
    "build": "pkg . --targets node18-win-x64 --output TrustWipeAgent.exe",
    "build-debug": "pkg . --debug --targets node18-win-x64 --output TrustWipeAgent.exe"
  },
  "pkg": {
    "scripts": [
      "./core/socketClient.js",
      "./core/systemEngine.js",
      "./core/taskEngine.js",
      "./core/jobStore.js"
    ],
    "assets": [
      "./core/**/*"
    ],
    "targets": [
      "node18-win-x64"
    ]
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "socket.io-client": "^4.8.3"
  }
}
